# Database Configuration (Supabase)
# Formato para Direct Connection:
# DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres?sslmode=require"
# Nota: Si tu password tiene caracteres especiales, debes hacer URL encoding (ej: @ -> %40)
# ⚠️ CRÍTICO: Siempre incluir ?sslmode=require al final para Supabase
# ⚠️ En producción (Vercel), asegúrate de que DATABASE_URL incluya ?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# Server Configuration
PORT=3001
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# JWT Configuration (unused today — reserved for a future first-party auth flow)
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=7d

# Supabase project URL, used to fetch the JWKS that verifies the access_token
# sent by the frontend (no shared secret needed — verification uses Supabase's
# public signing key). Find it in Supabase → Project Settings → API → Project URL.
SUPABASE_URL=https://your-project-ref.supabase.co

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100




